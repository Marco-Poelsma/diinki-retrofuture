{
    "layer": "bot",
    "spacing": 0,
    "height": 0,
    "margin-bottom": 0,
    "margin-top": 8,
    "position": "top",
    "margin-right": 0,
    "margin-left": 0,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["custom/applauncher"],
    "modules-right": ["custom/cputemp", "memory", "network", "battery", "pulseaudio", "tray", "clock"],

    "sway/workspaces" : {
        "all-outputs": false,
        "tooltip": false
    },

    "custom/applauncher": {
        "format": "◯",
        "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y=15",
        "tooltip": false
    },

    "tray" : {
        "spacing": 10,
        "tooltip": false
    },

    "clock": {
        "interval": 1,
        "format": "󱑍 {:%Y-%m-%dT%H:%M:%S}",
        "tooltip": true,
        "tooltip-format": "{:%Y-%m-%d}",
        "on-click": "pgrep gnome-calendar > /dev/null 2>&1 && killall gnome-calendar || gnome-calendar"

    },

    "network": {
        "format-wifi": "{icon}  {bandwidthUpBits} : {bandwidthDownBits}",
        "format-ethernet": "󰈀   {bandwidthUpBits} : {bandwidthDownBits}",
        "format-disconnected": "󰤭  No Network",
        "format-icons": ["󰤟", "󰤟", "󰤢", "󰤥", "󰤨"],
        "interval": 5,
        "tooltip": false,
        "on-click": "pgrep iwgtk > /dev/null 2>&1 && killall iwgtk || iwgtk"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "max-volume": 150,
        "format": "SPK({volume}%)",
        "format-bluetooth": "BTH({volume}%)",
        "format-icons": [
        "",
        "",
        ""
        ],
        "nospacing": 1,
        "format-muted": " ",
        "on-click": "pgrep pavucontrol > /dev/null 2>&1 && killall pavucontrol || pavucontrol",
        "tooltip": false
    },

    "battery": {
        "interval": 5,
        "states": {
        "warning": 30,
        "critical": 15
        },
        "format": "BAT({capacity}%)",
        "format-charging": "CHG({capacity}%)",
        "format-plugged": "PLG({capacity}%)",
        "format-alt": "BAT({capacity}%)",
        "format-full": "BAT FULL",
        "format-icons": [
        "",
        "",
        ""
        ]
    },

    "custom/cputemp": {
        "exec": "~/.config/waybar/cpu_temp.sh",
        "interval": 2,
        "return-type": "json",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "RAM({used:0.1f}G)"
    }
}